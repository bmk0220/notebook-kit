[debug] [2026-04-27T09:35:32.531Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/notebook-kit/rulesets {"name":"projects/notebook-kit/rulesets/e867ef93-043c-4815-8430-1aa7a0d39b80","source":{"files":[{"content":"rules_version = '2';\n\nservice firebase.storage {\n  match /b/{bucket}/o {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n    function isAdmin() {\n      return isSignedIn() && request.auth.token.email == 'admin@notebookkit.com';\n    }\n\n    match /{allPaths=**} {\n      // Allow any signed-in user to read files (marketplace kits are public for auth users)\n      allow read: if isSignedIn();\n      \n      // Restrict all write operations (upload, delete) to administrators only\n      allow write: if isAdmin();\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-04-27T09:35:32.592975Z","metadata":{"services":["firebase.storage"]}}
