{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22"
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "source": ".",
    "frameworksBackend": {
      "region": "us-central1"
    },
    "predeploy": [
      "powershell -Command \"Remove-Item -Recurse -Force .next/cache -ErrorAction SilentlyContinue\""
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "plans/**",
      "media/**",
      "scratch/**",
      "*.md",
      "implementation_plan.md",
      "task.md",
      "walkthrough.md"
    ]
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "Notebook Kit",
        "supportEmail": "admin@notebookkit.com"
      }
    }
  }
}
