rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Simplify isAdmin: use simpler query or check against known admin list
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@notebookkit.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /kits/{kitId} {
      allow read: if resource.data.status == 'published' || (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()));
      allow write: if isAdmin();
    }

    match /kits_content/{kitId} {
      allow read: if get(/databases/$(database)/documents/kits/$(kitId)).data.status == 'published' || 
                    (isSignedIn() && (get(/databases/$(database)/documents/kits/$(kitId)).data.userId == request.auth.uid || isAdmin()));
      allow write: if isAdmin();
    }

    match /user_kits/{accessId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /kit_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /requests/{requestId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.partnerId == request.auth.token.email ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner' && 
         resource.data.partnerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.partnerCode)
      ));
      allow write: if false; 
    }

    match /marketing_assets/{assetId} {
      allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner');
      allow write: if isAdmin();
    }

    match /partner_requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userEmail == request.auth.token.email);
      allow write: if isAdmin();
      allow create: if isSignedIn();
    }

    match /payout_requests/{docId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userEmail == request.auth.token.email);
      allow create: if isSignedIn() && request.resource.data.userEmail == request.auth.token.email;
      allow update, delete: if isAdmin();
    }

    match /partner_codes/{code} {
      allow read: if true;
      allow write: if isAdmin();
    }

  }
}
