rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /{allPaths=**} {
      // Allow any signed-in user to read files (marketplace kits are public for auth users)
      allow read: if isSignedIn();
      
      // Restrict all write operations (upload, delete) to administrators only
      allow write: if isAdmin();
    }
  }
}
